#include <stdio.h>

int main(){

    int i, j, k;
    int A[2][3], B[3][2], C[2][2];

    for(i=0; i<2; i++){
        for(j=0; j<3; j++){
            printf("Digite o elemento linha %d coluna %d da matriz A: ", i+1, j+1);
            scanf("%d", &A[i][j]);
        }
    }
    for(i=0; i<3; i++){
        for(j=0; j<2; j++){
            printf("Digite o elemento linha %d coluna %d da matriz B: ", i+1, j+1);
            scanf("%d", &B[i][j]);
        }
    }
    for(i=0; i<2; i++){
        for(j=0; j<2; j++){
            C[i][j] = 0;
            for(k=0; k<3; k++){
                C[i][j] += A[i][k] * B[k][j];
            }
        }
    }
    for(i=0; i<2; i++){
        for(j=0; j<2; j++){
            printf("%d ", C[i][j]);
        }
        printf("\n");
    }
    return 0;
}
