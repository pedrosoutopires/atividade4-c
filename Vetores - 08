#include <stdio.h>

int vetor(int i, int v[i]){

    int j, pares = 0;

    for (j=0; j<i; j++){
        if (v[j] % 2 == 0){
            pares ++;
        }
    }
    return pares;
}

int main(){

    int tamanho, funcao, i;

    printf("Digite o tamanho do vetor: ");
    scanf("%d", &tamanho);

    int numerosvetor[tamanho];

    for (i=0; i<tamanho; i++){
        printf("Digite o numero %d do vetor: ", i+1);
        scanf("%d", &numerosvetor[i]);
    }

    funcao = vetor(tamanho, numerosvetor);

    printf("O numero de pares dentro do vetor e: %d", funcao);

    return 0;
}
