#include <stdio.h>
#include <string.h>

int main (){

    int i, contadorA = 0, contadortotal = 0;
    char frase[20];

    printf("Digite uma frase de ate 20 caracteres (contando com o espaco): ");
    scanf("%19[^\n]", frase);

    for(i=0; frase[i]!='\0'; i++){
        contadortotal++;
        if(frase[i]=='a' || frase[i]=='A'){
            contadorA++;
        }
    }
    printf("O numero de caracteres e: %d\nO numero de letras 'A' e: %d", contadortotal, contadorA);

    return 0;
}
