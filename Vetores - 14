#include <stdio.h>
#include <string.h>

int vogal(char palavra[20]){

    int i, vogais = 0;

    for(i=0; palavra[i]!='\0'; i++){
        if (palavra[i]=='a'||palavra[i]=='e'||palavra[i]=='i'||palavra[i]=='o'||palavra[i]=='u'||palavra[i]=='A'||palavra[i]=='E'||palavra[i]=='I'||palavra[i]=='O'||palavra[i]=='U'){
            vogais++;
        }
    }

    return vogais;
}

int main(){

    int i;
    char palavra[20];

    printf("Digite uma palavra: ");
    scanf("%19[^\n]", palavra);

    printf("O numero de vogais e: %d", vogal(palavra));
    return 0;
}
