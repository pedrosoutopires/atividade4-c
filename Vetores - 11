#include <stdio.h>

void ordenar(int v[], int tamanho){

    int i, j, aux;

    for(i = 0; i < tamanho - 1; i++){
        for(j = 0; j < tamanho - 1; j++){

            if(v[j] > v[j + 1]){
                aux = v[j];
                v[j] = v[j + 1];
                v[j + 1] = aux;
            }

        }
    }

}

int main(){

    int tamanho, i;

    printf("Digite o tamanho do vetor: ");
    scanf("%d", &tamanho);

    int vetor[tamanho];

    for(i = 0; i < tamanho; i++){
        printf("Digite o numero %d do vetor: ", i + 1);
        scanf("%d", &vetor[i]);
    }

    ordenar(vetor, tamanho);

    printf("Vetor em ordem crescente: ");

    for(i = 0; i < tamanho; i++){
        printf("%d ", vetor[i]);
    }

    return 0;
}
