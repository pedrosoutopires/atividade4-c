#include <stdio.h>
#include <string.h>

int main (){

    int i;
    char nome[20];

    printf("Digite seu nome completo: ");
    scanf("%19[^\n]", nome);

    printf("Nome maiusculo: ");

    for(i=0; nome[i]!='\0'; i++){
        if(nome[i]>='a' && nome[i]<='z'){
            nome[i] -= 32;
            printf("%c", nome[i]);
        }
        else{
            printf("%c", nome[i]);
        }
    }

    printf("\nNome minusculo: ");

    for(i=0; nome[i]!='\0'; i++){
        if(nome[i]>='A' && nome[i]<='Z'){
            nome[i] += 32;
            printf("%c", nome[i]);
        }
        else {
            printf("%c", nome[i]);
        }
    }

    return 0;
}
