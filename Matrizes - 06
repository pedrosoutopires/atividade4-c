#include <stdio.h>

int main(){

    int i, j;
    float matriz[3][2], transposta[2][3];

    for(i=0; i<3; i++){
        for(j=0; j<2; j++){
            printf("Digite o elemento linha %d coluna %d da matriz: ", i+1, j+1);
            scanf("%f", &matriz[i][j]);
        }
    }
    for(i=0; i<2; i++){
        for(j=0; j<3; j++){
            transposta[i][j] = matriz[j][i];
            printf("%.2f  ", transposta[i][j]);
        }
        printf("\n");
    }

    return 0;
}
