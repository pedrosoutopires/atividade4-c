#include <stdio.h>

int main (){

    int v1[10], i, j, repetidos;

    for(i=0; i<10; i++){
        printf("Digite o numero %d do vetor v1: ", i+1);
        scanf("%d", &v1[i]);
    }

    printf("v2: ");

    for(i=0; i<10; i++){
        repetidos = 0;
        for(j=0; j<i; j++){
            if(v1[i] == v1[j]){
                repetidos++;
            }
        }
        if (repetidos == 0){
            printf("%d ", v1[i]);
        }
    }
    return 0;
}
