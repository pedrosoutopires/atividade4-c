#include <stdio.h>
#include <string.h>

int main(){

    int i, j, maior, linha, coluna;
    int matriz[3][4];

    for(i=0; i<3; i++){
        for(j=0; j<4; j++){
            printf("Digite o elemento linha %d coluna %d da matriz: ", i+1, j+1);
            scanf("%d", &matriz[i][j]);
            maior = matriz[i][j];
            linha = i;
            coluna = j;
        }
    }
    for(i=0; i<3; i++){
        for(j=0; j<4; j++){
            if(maior < matriz[i][j]){
                maior = matriz[i][j];
                linha = i;
                coluna = j;
            }
        }
    }
    printf("%d, linha %d, coluna %d", maior, linha+1, coluna+1);

    return 0;
}
