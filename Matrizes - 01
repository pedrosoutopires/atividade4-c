#include <stdio.h>

int main(){

    int matriz[3][2] = {{1, 2}, {3, 4}, {5, 6}};
    int i, j;

    for (i=0; i<3; i++){
        for (j=0; j<2; j++){
            printf("Digite o elemento [%d] [%d] ", i, j);
            scanf("%d", &matriz[i][j]);
        }
    }
    printf("\nMatriz: \n");

    for (i=0; i<3; i++){
        for (j=0; j<2; j++){
            printf("%d ", matriz[i][j]);
        }
        printf("\n");
    }

    return 0;
}
