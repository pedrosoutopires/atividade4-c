#include <stdio.h>
#include <string.h>

int main(){

    int i, j, soma = 0;
    int matriz[4][4];

    for(i=0; i<4; i++){
        for(j=0; j<4; j++){
            printf("Digite o elemento linha %d coluna %d da matriz: ", i+1, j+1);
            scanf("%d", &matriz[i][j]);
        }
    }


    for(i=0; i<4; i++){
        for(j=0; j<4; j++){
            soma += matriz[i][j];
        }
        printf("Soma da linha %d: %d\n", i+1, soma);
        soma = 0;
    }
    for(j=0; j<4; j++){
        for(i=0; i<4; i++){
            soma += matriz[i][j];
        }
        printf("Soma da coluna %d: %d\n", j+1, soma);
        soma = 0;
    }

    return 0;
}
