#include <stdio.h>

int main(){

    int i, v[10], maior, posicao;

    printf("Digite um numero inteiro: ");
    scanf("%d", &v[0]);
    maior = v[0];
    posicao = 0;

    for(i=1; i<10; i++){
        printf("Digite um numero inteiro: ");
        scanf("%d", &v[i]);

        if (v[i] > maior){
            maior = v[i];
            posicao = i;
        }
    }
    printf("Maior: %d\nPosicao: %d", maior, posicao);

    return 0;
}
