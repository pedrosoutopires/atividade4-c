#include <stdio.h>

int main(){

    int i, j;
    int matriz[4][4];

    for(i=0; i<4; i++){
        for(j=0; j<4; j++){
            printf("Digite o elemento linha %d coluna %d: ", i+1, j+1);
            scanf("%d", &matriz[i][j]);
        }
    }

    for(i=0; i<4; i++){
        for(j=0; j<4; j++){
            printf("%d ", matriz[i][j]);
        }
        printf("\n");
    }

    printf("\nDiagonal principal: ");

    for(i=0; i<4; i++){
        for(j=0; j<4; j++){
            if(i == j){
                printf("%d ", matriz[i][j]);
            }
        }
    }

    printf("\nDiagonal secundaria: ");

    for(i=0; i<4; i++){
        for(j=0; j<4; j++){
            if(i + j == 3){
                printf("%d ", matriz[i][j]);
            }
        }
    }

    return 0;
}
